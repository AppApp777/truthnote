# ===== LLM 提供商 =====
# openai     : OpenAI 兼容端点，配合国产模型（生产推荐）
# claude_cli : 本地开发，无需任何 key（零 key 跑通）
# anthropic  : 直连 Anthropic
LLM_PROVIDER=openai

# ===== 国产分层模型（生产推荐）=====
# 基础层跑海量初筛，关键层做关键判定——架构让便宜的国产模型也产出可靠结果
DEFAULT_MODEL=deepseek-v4-flash
STRONG_MODEL=qwen-max
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=
GLM_API_KEY=

# ===== 证据搜索 =====
# bocha_wiki : 博查 Bocha，中文权威源召回好（推荐，需 key：open.bocha.cn）
# so360      : 360 网页搜索，无需 key（零 key 跑通）
# tavily / mock
SEARCH_PROVIDER=bocha_wiki
BOCHA_API_KEY=
TAVILY_API_KEY=
QIHOO_API_KEY=

# ===== 官方辟谣库检索（记忆层 debunk_index）=====
# 命中只当作一条证据、判定仍重新核算（不短路）。演示数据放 data/rumor_library 下。
ENABLE_DEBUNK_INDEX=true

# ===== 应用 =====
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# 零 key 快速体验：LLM_PROVIDER=claude_cli + SEARCH_PROVIDER=so360，不填任何 key 即可跑通。