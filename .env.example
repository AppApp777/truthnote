# LLM 提供商（claude_cli | anthropic | openai）
# 开发阶段：claude_cli（无需 API key）
# Demo 阶段：openai（配合通义千问/GLM/DeepSeek）
LLM_PROVIDER=claude_cli

# Claude（开发阶段默认）
ANTHROPIC_API_KEY=

# 通义千问（Demo 阶段推荐 — 切换方式：LLM_PROVIDER=openai, DEFAULT_MODEL=qwen-max）
DASHSCOPE_API_KEY=
# 智谱 GLM（兜底 — DEFAULT_MODEL=glm-4）
GLM_API_KEY=
# DeepSeek（备选 — DEFAULT_MODEL=deepseek-chat）
DEEPSEEK_API_KEY=

# 默认模型（留空则按 provider 自动选）
DEFAULT_MODEL=

# 快速模型（用于非关键 Agent：提取/路由/排序/回复生成）
# 留空则全用默认模型；设了则 FactChecker/Skeptic 用默认，其余用快模型
FAST_MODEL=

# 搜索配置（mock | qihoo360 | so360 | tavily）
# so360: 直接走 360 网页搜索 (so.com)，无需 API key（推荐）
# qihoo360: 有 API key 走 360 智搜 API，无 key 自动走 360 网页搜索
# tavily: Tavily API + So360 fallback
SEARCH_PROVIDER=so360
TAVILY_API_KEY=

# 360 智搜 API（可选，无 key 会自动用 360 网页搜索）
QIHOO_API_KEY=
QIHOO_BASE_URL=https://api.360.cn

# 应用
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
